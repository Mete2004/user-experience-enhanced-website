    {% assign mobile_logo = "/assets/logo-compact-oost.svg" %}
    {% assign desktop_logo = "/assets/logo-lang-oost.svg" %}
    {% assign current_district = 'oost' %}

    {% render 'partials/head.liquid',
        pageClass: "oost",
        mobile_logo: mobile_logo,
        desktop_logo: desktop_logo
    %}

    <main class="main-oost">

        <div class="titel-district">
            <h1>Oost</h1>
        </div>

        {% render 'partials/targetgroups.liquid', 
            selectedTargetGroup: selectedTargetGroup, 
            current_district: current_district %}

        <section class="section-cards">
            <div class="cards-medium">
                {% for story in stories %}
                    {% render 'partials/card-medium.liquid', story: story, categories: categories %}
                {% endfor %}
            </div>
        </section>

    </main>

    {% render 'partials/foot.liquid',
        mobile_logo: mobile_logo,
        desktop_logo: desktop_logo
    %}